{
	"$schema": "https://turborepo.dev/schema.json",
	"ui": "stream-with-experimental-timestamps",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": [".next/**", "!.next/cache/**", "dist/**", "build/**"]
		},
		"@apps/docs#build": {
			"dependsOn": ["^build"],
			"outputs": [".next/**", "!.next/cache/**"],
			"env": ["SPONSORS_GITHUB_TOKEN", "PLAUSIBLE_SCRIPT_URL", "PLAUSIBLE_SCRIPT_PATH"]
		},
		"test": {
			"dependsOn": ["^build"]
		},
		"lint": {
			"dependsOn": ["^build"]
		},
		"dev": {
			"cache": false,
			"persistent": true
		}
	}
}
